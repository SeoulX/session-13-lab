// Paste inside your Jenkinsfile between Vuln Scan (Source) and Build.
// Parallel branch time = max(children), NOT sum — a 10-min Claude
// review parallel to a 40-s Test costs 10 min, not 10:40.

stage('Analysis') {
  parallel {
    stage('Test') {
      steps {
        container('tester') {
          sh './devops/test.sh'
        }
      }
    }
    stage('Vuln Scan (Source)') {
      steps {
        container('trivy') {
          sh 'trivy fs . --scanners vuln,secret,misconfig --severity HIGH,CRITICAL --exit-code 0'
        }
      }
    }
    stage('Claude review') {
      steps {
        container('tools') {
          sh '''
            apk add --no-cache curl bash jq nodejs npm >/dev/null 2>&1 || true
            npm install -g @anthropic-ai/claude-code || true
            ./claude-review.sh || true    # soft-fail during rollout
          '''
          archiveArtifacts artifacts: 'claude-review.json', allowEmptyArchive: true
        }
      }
    }
  }
}
